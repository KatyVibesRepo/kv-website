# KV Website production/development environment template
# Do not commit real secrets. KV Website should not contain Stripe secret keys, Prisma URLs, or admin credentials.

# Local development: KV ReservationService running on port 3001
NEXT_PUBLIC_KVRS_BASE_URL=http://localhost:3001
KVRS_BASE_URL=http://localhost:3001

# Production example after DNS cutover. Use the stable KVRS/admin domain, not a Cloudflare tunnel.
# NEXT_PUBLIC_KVRS_BASE_URL=https://admin.katyvibes.com
# KVRS_BASE_URL=https://admin.katyvibes.com

# Optional overrides. Leave blank unless the endpoint path differs from the default.
# KVRS_PUBLIC_API_BASE_URL=https://admin.katyvibes.com/api/public
# NEXT_PUBLIC_KVRS_CHECKOUT_URL=https://admin.katyvibes.com/api/checkout
# KVRS_ORDER_LOOKUP_URL=https://admin.katyvibes.com/api/orders/by-session
