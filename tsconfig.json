{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "es2022"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "_patch_backups",
    "**/_patch_backups/**",
    "_agentlink_backups",
    "**/_agentlink_backups/**",
    "__MACOSX",
    "**/__MACOSX/**",
    "_*_patch",
    "**/_*_patch/**",
    "_kv_*_patch",
    "**/_kv_*_patch/**",
    "kv_*_patch",
    "**/kv_*_patch/**",
    ".next"
  ]
}
